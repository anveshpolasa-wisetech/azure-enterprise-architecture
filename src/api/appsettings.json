{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "Serilog": {
      "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
      "MinimumLevel": "Information",
      "WriteTo": [
        { "Name": "Console" },
        { "Name": "File", "Args": { "path": "Logs/log-.txt", "rollingInterval": "Day" } },
        { "Name": "ApplicationInsights", "Args": { "instrumentationKey": "YOUR_INSTRUMENTATION_KEY" } }
      ]
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=tcp:your_server.database.windows.net;Initial Catalog=your_db;Persist Security Info=False;User ID=your_user;Password=your_password;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;",
    "ServiceBus": "Endpoint=sb://your_servicebus_NAMESPACE.servicebus.windows.net/;SharedAccessKeyName=your_key_name;SharedAccessKey=your_access_key;"
  },
  "AzureKeyVault": {
    "Url": "https://your-keyvault-name.vault.azure.net/",
    "TenantId": "your_tenant_id",
    "ClientId": "your_client_id"
  },
  "ApplicationInsights": {
    "InstrumentationKey": "YOUR_INSTRUMENTATION_KEY"
  },
  "ServiceBusConfig": {
    "QueueName": "your_queue_name",
    "SubscriptionName": "your_subscription_name"
  },
  "MigrationsAssembly": "YourNamespace.Migrations"
}